# Root-level gitignore for the Sapling monorepo.
#
# Sub-projects (sapling-api, sapling-web) have their own .gitignore for
# language-specific excludes. This file covers the repo root plus things
# that didn't fit neatly into a sub-project (like deploy/).

# macOS junk
.DS_Store

# QA screenshots accumulated at the repo root from playwright/manual
# review sessions. Not part of the codebase — keep them local.
/*.png

# Research bulk: large PDFs + OCR text files for SAAGA, SAMAC, citrus,
# misc. Numerical findings get seeded into migrations with citations;
# the raw research artifacts stay local-only (size + rights).
sapling-api/data/saaga/
sapling-api/data/samac/
sapling-api/data/citrus/
sapling-api/data/misc/
sapling-api/data/fertasa_handbook/images_ocr/

# Seed scratch — fake_reports are local fixtures for ad-hoc validation,
# not committed seeds.
sapling-api/seeds/fake_reports/

# Smoke-rendered PDFs are regeneratable; the JSON fixtures are the
# committed source of truth.
sapling-api/tests/fixtures/soil_report_smoke.pdf
sapling-api/tests/fixtures/soil_report_e2e.pdf
sapling-api/tests/fixtures/torture_test.pdf
sapling-api/tests/fixtures/toc_check_mac.pdf
sapling-api/tests/fixtures/final_check_mac.pdf

# FERTASA scraper — holds authenticated session; never commit
sapling-api/data/fertasa_handbook/session_cookie.txt
sapling-api/data/fertasa_handbook/maize_pdf_pages/
sapling-api/data/fertasa_handbook/maize_ocr/

# SASRI Information Sheets — explicit copyright notice forbids redistribution.
# Numerical thresholds ARE facts (uncopyrightable) so we SEED them into
# migrations with full citation, but keep the raw PDFs local-only.
sapling-api/data/sasri/

# OCR pipeline scratch (per-page PNGs + per-page OCR; combined .txt is kept)
sapling-api/data/arc_gci/pages/
sapling-api/data/arc_gci/ocr/

# Claude Code local state — never commit IDE/agent settings
.claude/
.playwright-mcp/

# Secrets — deploy/.env has the docker-compose environment and MUST NOT ship
.env
deploy/.env
deploy/*.env
*.env.local
*.env.production

# Python venvs at the root, just in case
venv/
.venv/

# IDE
.vscode/
.idea/

# Build artifacts
dist/
build/
*.egg-info/
